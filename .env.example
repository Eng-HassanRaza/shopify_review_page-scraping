# Copy this file to .env and fill in your values

# Required: Serper.dev (geo-accurate Google Search for URL finding)
# Add up to 3 keys separated by commas — rotated automatically when one is exhausted
SERPER_API_KEYS=your_serper_key_1,your_serper_key_2,your_serper_key_3

# Required: Google Gemini (URL reasoning + email search fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI (email filtering via GPT — skip if not needed)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_leads
# Or use individual parts:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=shopify_leads
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Server
HOST=0.0.0.0
PORT=5001
DEBUG=false

# Tuning (optional — defaults are sensible)
URL_CONFIDENCE_THRESHOLD=0.5
INTER_STORE_DELAY=3.0
STORE_MAX_ATTEMPTS=3
EMAIL_MAX_PAGES=40
EMAIL_DELAY=0.5
EMAIL_TIMEOUT=20
GEMINI_MAX_RETRIES=3
# Gemini free tier is 15 RPM — keep this at 15 or higher to avoid 429 storms.
# Code enforces a hard floor of 15 s regardless of this value.
GEMINI_RETRY_DELAY=15
