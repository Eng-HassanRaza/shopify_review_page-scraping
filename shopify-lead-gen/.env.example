# Copy this file to .env and fill in your values

# Required: Google Gemini (URL finding)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI (email filtering via GPT — skip if not needed)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_leads
# Or use individual parts:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=shopify_leads
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Server
HOST=127.0.0.1
PORT=5001
DEBUG=true

# Tuning (optional — defaults are sensible)
URL_CONFIDENCE_THRESHOLD=0.6
EMAIL_MAX_PAGES=40
EMAIL_DELAY=0.5
EMAIL_TIMEOUT=20
GEMINI_MAX_RETRIES=3
